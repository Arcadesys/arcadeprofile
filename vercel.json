{
  "version": 2,
  "buildCommand": "if [ -n \"$DATABASE_URL\" ]; then npm run migrate; fi && npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/posts/publish-scheduled",
      "schedule": "0 9 * * *"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
} 