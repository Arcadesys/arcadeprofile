# Copy to .env.local and fill in values. Never commit real secrets.

# Public site URL (used in emails, RSS, unsubscribe links)
NEXT_PUBLIC_SITE_URL=https://thearcades.me

# Cron routes (e.g. scheduled publish, email test)
CRON_SECRET=

# --- Payload CMS
PAYLOAD_API_URL=http://localhost:3000
PAYLOAD_API_KEY=f9787d7e-8181-422a-ad7b-097416f425e7

# MCP HTTP endpoint auth — separate from PAYLOAD_API_KEY so they rotate independently.
# Generate with: openssl rand -hex 32
MCP_API_KEY=

# Database
DATABASE_URI=
# Alias supported by some libraries in this repo
DATABASE_URL=

# --- ActiveCampaign (blog newsletter on first publish — see docs/activecampaign-blog-notifications.md)
# Primary names (used by lib/activecampaign.ts):
AC_API_URL=
AC_API_KEY=
AC_NEWSLETTER_LIST_ID=
# Verified sender in ActiveCampaign (or rely on POSTMARK_FROM_EMAIL as fallback)
AC_NEWSLETTER_FROM_EMAIL=
AC_NEWSLETTER_FROM_NAME=The Arcades
AC_NEWSLETTER_REPLY_TO=
#
# Legacy aliases (same values) if you already use these names:
# ACTIVECAMPAIGN_API_URL, ACTIVECAMPAIGN_API_KEY, ACTIVECAMPAIGN_LIST_ID,
# ACTIVECAMPAIGN_FROM_EMAIL, ACTIVECAMPAIGN_FROM_NAME, ACTIVECAMPAIGN_REPLY_TO

# --- Postmark (transactional test route and optional legacy batch code in lib/postmark.ts)
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=
POSTMARK_FROM_NAME=The Arcades
POSTMARK_BROADCAST_STREAM=broadcast
POSTMARK_TRANSACTIONAL_STREAM=outbound
# Optional safety rail: fail boot in production if token is missing
POSTMARK_REQUIRED_IN_PROD=false
# Optional webhook auth token for /api/postmark/webhook
POSTMARK_WEBHOOK_SECRET=
