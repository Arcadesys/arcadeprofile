{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js Dev Server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "serverReadyAction": {
        "pattern": "ready on",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    }
  ]
}
